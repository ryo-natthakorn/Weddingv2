# Copy this file to ".env" and fill in the real values.
# Vite only exposes variables prefixed with VITE_ to the app.

# YouTube Data API key — used by the Music Player to fetch CC lyrics.
VITE_YOUTUBE_API_KEY=your_api_key_here

# The proposal song video id.
VITE_YOUTUBE_VIDEO_ID=p8iVeHphD3c

# Google Apps Script web app URL that records RSVP submissions.
# See google-apps-script.gs for deployment steps.
VITE_GOOGLE_SCRIPT_URL=your_apps_script_url_here
